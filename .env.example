# --- Ethereum Node Configuration ---
# Infura, Alchemy 또는 자체 노드(Geth/Erigon)의 엔드포인트를 입력하세요.
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
CHAIN_ID=1

# --- Database Configuration (PostgreSQL) ---
# pgx 드라이버와 sqlc에서 사용할 연결 문자열입니다.
# 형식: postgres://사용자:비밀번호@호스트:포트/DB명?옵션
DATABASE_URL=postgres://postgres:password@localhost:5432/socialproof?sslmode=disable

# --- Cache & Task Queue (Redis) ---
# Asynq 워커가 작업을 쌓고 캐시를 처리할 공간입니다.
REDIS_ADDR=localhost:6379

# --- Application Settings ---
IDX_WORKER_COUNT=2
IDX_BATCH_SIZE=2
IDX_BACKFILL_QUEUE_SIZE=3
IDX_TASK_QUEUE_SIZE=100
IDX_START_BLOCK=0
IDX_SLEEP_DURATION=10s
LOG_LEVEL=debug
APP_ENV=development

# --- (Optional) External API Keys ---
# 이전 단계에서 다룬 유튜브 수집 기능과 병합할 경우 필요합니다.
YOUTUBE_API_KEY=AIzaSy...

DB_USER=postgres
DB_PASSWORD=mysecretpassword
DB_NAME=socialproof